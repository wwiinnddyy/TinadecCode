    "date-fns": "^4.2.1",
    "electron": "^39.2.4",
    "lucide-react": "^1.16.0",
    "react-day-picker": "^10.0.1",
    "recharts": "^3.8.0",
    "shadcn": "^4.7.0",
    "tw-animate-css": "^1.4.0",
    "vue": "^3.5.24",
    "vue-i18n": "^11.4.4",
    "vue-router": "^5.0.7"
  },
