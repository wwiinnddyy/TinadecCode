  "scripts": {
    "dev": "concurrently -k -n vite,electron -c cyan,green \"vite --host 127.0.0.1\" \"wait-on http://127.0.0.1:5173 && cross-env VITE_DEV_SERVER_URL=http://127.0.0.1:5173 electron .\"",
    "electron": "cross-env VITE_DEV_SERVER_URL=http://127.0.0.1:5173 electron .",
    "build": "vue-tsc --noEmit && vite build",
    "preview": "vite preview --host 127.0.0.1",
    "test": "vitest run"
  },
